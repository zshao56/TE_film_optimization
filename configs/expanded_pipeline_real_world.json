{
  "run": {
    "data_generation": false,
    "training": false,
    "evaluation": false,
    "real_world_benchmark": true
  },
  "environment": {
    "cuda_visible_devices": "1",
    "omp_num_threads": "1",
    "mkl_num_threads": "1",
    "openblas_num_threads": "1"
  },
  "data_generation": {
    "samples": 100000,
    "cores": 8,
    "mode": "mixed",
    "structured_ratio": 0.8,
    "seed": 42,
    "profile": "expanded",
    "clear_existing": false,
    "allow_delete_data": false,
    "log_path": "logs/01_generate_expanded_configured.log",
    "grid": {
      "Lx": 0.01,
      "Ly": 0.01,
      "nx": 50,
      "ny": 50,
      "nz": 20
    },
    "sampling": {
      "environment": {
        "T_air_range": [293.0, 303.0]
      },
      "convection": {
        "side_scale_range": [0.6, 1.2],
        "regimes": {
          "natural": {"range": [2.0, 15.0], "weight": 0.35, "code": 0},
          "weak_forced": {"range": [15.0, 50.0], "weight": 0.25, "code": 1},
          "forced": {"range": [50.0, 150.0], "weight": 0.25, "code": 2},
          "strong_forced": {"range": [150.0, 500.0], "weight": 0.15, "code": 3}
        }
      },
      "hot_boundary": {
        "type_weights": {
          "uniform": 0.4,
          "linear_gradient": 0.3,
          "gaussian_hotspot": 0.3
        },
        "uniform_temp_range": [308.0, 373.0],
        "linear_mean_range": [318.0, 363.0],
        "linear_amplitude_range": [5.0, 30.0],
        "linear_directions": ["x", "y"],
        "linear_clip_range": [308.0, 373.0],
        "gaussian_base_range": [303.0, 335.0],
        "gaussian_min_peak_delta": 10.0,
        "gaussian_peak_floor": 330.0,
        "gaussian_peak_max": 373.0,
        "gaussian_clip_range": [303.0, 373.0],
        "hotspot_x_range": [0.15, 0.85],
        "hotspot_y_range": [0.15, 0.85],
        "hotspot_sigma_range": [0.06, 0.22]
      },
      "thickness_bands": {
        "thin": {"range": [0.0001, 0.0005], "weight": 0.2},
        "medium": {"range": [0.0005, 0.002], "weight": 0.6},
        "thick": {"range": [0.002, 0.005], "weight": 0.2}
      },
      "materials": {
        "k_low_range": [0.05, 0.8],
        "k_ratio_log_range": [3.0, 80.0],
        "k_high_clip": [0.8, 10.0],
        "min_k_gap": 0.75
      },
      "curvature": {
        "level_weights": {
          "0": 0.25,
          "025": 0.15,
          "05": 0.2,
          "075": 0.15,
          "1": 0.15,
          "random": 0.1
        },
        "random_level_range": [0.0, 1.0],
        "bend_axes": ["x", "y"]
      }
    }
  },
  "training": {
    "cuda_visible_devices": "1",
    "batch_size": 128,
    "epochs": 80,
    "seed": 42,
    "workers": 8,
    "lr": 0.0003,
    "weight_decay": 0.001,
    "patience": 12,
    "lr_patience": 5,
    "normalize_target": true,
    "top_quantile": 0.9,
    "top_weight": 3.0,
    "include_boundary_channel": true,
    "run_name": "expanded_v2_configured",
    "metadata_report_dir": "results/metadata/expanded_v2_configured",
    "log_path": "logs/02_train_expanded_v2_configured.log"
  },
  "evaluation": {
    "cuda_visible_devices": "1",
    "model_path": "results/models/best_thermonet.pth",
    "splits": ["val", "test"],
    "seed": 42,
    "batch_size": 256,
    "workers": 8,
    "top_quantile": 0.9,
    "output_dir": "results/evaluation/expanded_v2_configured",
    "log_path_template": "logs/03_eval_expanded_v2_{split}.log"
  },
  "real_world_benchmark": {
    "cuda_visible_devices": "1",
    "model_path": "results/models/best_thermonet.pth",
    "num_candidates": 50000,
    "top_k": 500,
    "verify_count": 50,
    "batch_size": 512,
    "verify_workers": 8,
    "save_every": 10,
    "seed": 20260512,
    "mode": "mixed",
    "structured_ratio": 0.9,
    "output_dir": "results/real_world_benchmarks/expanded_v2_configured",
    "log_path": "logs/04_real_world_benchmark_configured.log",
    "scenarios": [
      {
        "key": "battery_ac_half_cylinder",
        "label": "Battery surface cooling",
        "description": "Center hotspot 390 K, edge 360 K, half-cylinder curvature, strong air-conditioner convection.",
        "T_air": 298.15,
        "h_c": 180.0,
        "h_c_side": 180.0,
        "curvature_level": 1.0,
        "bend_axis": "x",
        "hot_boundary": {"kind": "center_hotspot", "center_temp": 390.0, "edge_temp": 360.0, "sigma": 0.24}
      },
      {
        "key": "skin_slight_curve_uniform",
        "label": "Skin patch",
        "description": "Uniform 37 C body temperature, slight curvature, natural convection.",
        "T_air": 298.15,
        "h_c": 8.0,
        "h_c_side": 8.0,
        "curvature_level": 0.1,
        "bend_axis": "x",
        "hot_boundary": {"kind": "uniform", "temperature": 310.15}
      },
      {
        "key": "glass_center_hot_natural",
        "label": "Glass panel",
        "description": "Center 70 C, edge 50 C, flat geometry, natural convection.",
        "T_air": 298.15,
        "h_c": 8.0,
        "h_c_side": 8.0,
        "curvature_level": 0.0,
        "bend_axis": "x",
        "hot_boundary": {"kind": "center_hotspot", "center_temp": 343.15, "edge_temp": 323.15, "sigma": 0.25}
      },
      {
        "key": "engine_forced_flat",
        "label": "Automotive engine surface",
        "description": "Very hot center, flat geometry, strong forced convection from driving airflow.",
        "T_air": 303.15,
        "h_c": 300.0,
        "h_c_side": 300.0,
        "curvature_level": 0.0,
        "bend_axis": "x",
        "hot_boundary": {"kind": "center_hotspot", "center_temp": 520.0, "edge_temp": 420.0, "sigma": 0.22}
      },
      {
        "key": "phone_linear_natural",
        "label": "Phone surface",
        "description": "One hot end and one cooler end, flat geometry, natural convection.",
        "T_air": 298.15,
        "h_c": 8.0,
        "h_c_side": 8.0,
        "curvature_level": 0.0,
        "bend_axis": "x",
        "hot_boundary": {"kind": "linear_gradient", "hot_temp": 333.15, "cold_temp": 303.15, "direction": "x"}
      }
    ]
  }
}
